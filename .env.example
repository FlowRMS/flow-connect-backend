# Database
PG_URL=postgresql://user:password@localhost:5432/flowconnect
DB_USER=flowconnect
DB_PASSWORD=flowconnect
DB_NAME=flowconnect

# Application
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO

# Authentication
AUTH_URL=https://auth.flowrms.com
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret

# GitHub (for private packages)
GITHUB_TOKEN=your-github-token

# Redis (optional)
REDIS_URL=redis://localhost:6379

# AWS (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
